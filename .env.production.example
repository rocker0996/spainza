# PostgreSQL
POSTGRES_DB=spainza
POSTGRES_USER=spainza
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=spainza-postgres
POSTGRES_PORT=5432

# Optional direct URL override
DATABASE_URL=postgresql://spainza:change_me_strong_password@spainza-postgres:5432/spainza

# Auth (SECRET_KEY for full API is taken from JWT_SECRET in docker-compose)
JWT_SECRET=change_me_super_long_random_secret_at_least_32_chars
COOKIE_SECURE=1

# Bootstrap admin credentials (created once if not exists)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password
BOOTSTRAP_ADMIN_NAME=Spainza Admin
BOOTSTRAP_ADMIN_ROLE=management

# Portal support account (numeric user id in SQLite)
PORTAL_SUPPORT_USER_ID=3

# Optional demo client user
BOOTSTRAP_DEMO_EMAIL=client@example.com
BOOTSTRAP_DEMO_PASSWORD=change_me_demo_password
BOOTSTRAP_DEMO_NAME=Demo Client
