# Auth (SECRET_KEY for full API is taken from JWT_SECRET in docker-compose)
JWT_SECRET=change_me_super_long_random_secret_at_least_32_chars
COOKIE_SECURE=1

# Bootstrap admin credentials (created once if not exists)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password
BOOTSTRAP_ADMIN_NAME=Spainza Admin
BOOTSTRAP_ADMIN_ROLE=management

# Portal support account (numeric user id in SQLite)
PORTAL_SUPPORT_USER_ID=3

# Optional demo client user
BOOTSTRAP_DEMO_EMAIL=client@example.com
BOOTSTRAP_DEMO_PASSWORD=change_me_demo_password
BOOTSTRAP_DEMO_NAME=Demo Client

# Public site URL (links in Telegram notifications and bot buttons)
PUBLIC_BASE_URL=https://spainza.com

# SMTP (SpaceWeb mail for registration / password reset)
# Put the real password in .env.deploy (local) or /opt/spainza/.env.production (server) — not here.
SMTP_HOST=smtp.spaceweb.ru
SMTP_PORT=465
SMTP_USERNAME=noreply@spainza.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@spainza.com
SMTP_USE_SSL=1
SMTP_USE_TLS=0

# Telegram bot (@spainza_bot) — worker container + LK notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=spainza_bot
# If the VPS cannot reach api.telegram.org, set an HTTPS proxy:
# TELEGRAM_HTTPS_PROXY=http://user:pass@proxy-host:port
