# App environment (set to production on server)
APP_ENV=development

# Dev-only built-in server (python run_server.py). Must stay 0 in production.
FLASK_DEBUG=1
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
FLASK_USE_RELOADER=1

# Required in production.
# Use a random value with at least 32 chars, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-strong-random-secret-key-min-32-chars

# Comma-separated trusted origins for CORS (no trailing slash).
# Leave empty for same-origin only.
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_ENABLED=1
AUTH_RATE_LIMIT_IP_MAX=12
AUTH_RATE_LIMIT_IP_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_EMAIL_MAX=6
AUTH_RATE_LIMIT_EMAIL_WINDOW_SECONDS=900
UPLOAD_RATE_LIMIT_IP_MAX=30
UPLOAD_RATE_LIMIT_IP_WINDOW_SECONDS=600
UPLOAD_RATE_LIMIT_USER_MAX=40
UPLOAD_RATE_LIMIT_USER_WINDOW_SECONDS=600
MESSAGE_RATE_LIMIT_IP_MAX=120
MESSAGE_RATE_LIMIT_IP_WINDOW_SECONDS=60
MESSAGE_RATE_LIMIT_USER_MAX=160
MESSAGE_RATE_LIMIT_USER_WINDOW_SECONDS=60

# Public absolute base URL (optional)
PUBLIC_BASE_URL=

# LK support account user id
PORTAL_SUPPORT_USER_ID=3

# Token and verification TTLs (seconds)
EMAIL_VERIFICATION_TTL_SECONDS=172800
PASSWORD_RESET_TTL_SECONDS=3600

# SMTP configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=1
# For providers that require implicit SSL (e.g. SpaceWeb on port 465): SMTP_USE_SSL=1, SMTP_USE_TLS=0
SMTP_USE_SSL=0

# Telegram bot for LK notifications (optional)
TELEGRAM_BOT_TOKEN=
# Fallback username if Telegram getMe is unreachable (without @)
TELEGRAM_BOT_USERNAME=spainza_bot
